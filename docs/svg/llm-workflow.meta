scope: LLM agent decision routing and query execution workflow
watch: LLM/workflow/agent.py, LLM/workflow/sql_agent.py, LLM/workflow/vector_db.py, service/mcp_server.py

nodes:
  User_Query: Entry point
  LLM_Runner: POST /run endpoint (LLM/controllers/llm_runner.py)
  Coordinator: GlobalHealthRouter agent (LLM/workflow/agent.py)
  Direct_Answer: General knowledge path (Rule A)
  SQLAnalyst: Data query path (Rule B) via MCP tools
  RAG: Document query path (Rule C) via ChromaDB
  Response: JSON with answer, references, execution_log

edges:
  User_Query -> LLM_Runner
  LLM_Runner -> Coordinator
  Coordinator -> Direct_Answer [label="Rule A: general"]
  Coordinator -> SQLAnalyst [label="Rule B: quantitative"]
  Coordinator -> RAG [label="Rule C: document"]
  SQLAnalyst -> MCP_Tools [label="get_db_description, get_db_schema, execute_db_query"]
  RAG -> ChromaDB [label="similarity search k=4"]
  Direct_Answer -> Response
  SQLAnalyst -> Response
  RAG -> Response
