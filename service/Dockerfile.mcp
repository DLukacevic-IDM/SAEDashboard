FROM python:3.11

RUN apt update && apt install curl vim procps git -y

ENV PYTHONPATH=/app:${PYTHONPATH}
ENV PATH=/app:${PATH}

RUN mkdir -p /app/service
RUN mkdir -p /app/service/helpers
RUN mkdir -p /app/service/data/shapefiles

WORKDIR /app

ADD setup.py README.md /app/service/
RUN cd service && pip install -e .[production] --use-deprecated=legacy-resolver
COPY ./requirements_mcp.txt /app/service/
RUN pip install --upgrade pip && pip install -r /app/service/requirements_mcp.txt

ADD . ./service

CMD ["python", "service/mcp_server.py"]
